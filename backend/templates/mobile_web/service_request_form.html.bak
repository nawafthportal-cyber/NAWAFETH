{% extends "mobile_web/base.html" %}{% load static %}
{% block title %}طلب خدمة — نوافــذ{% endblock %}
{% block body_class %}page-service-request{% endblock %}

{% block extra_css %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<style>
  body.page-service-request {
    background:
      radial-gradient(1100px 420px at 12% -10%, rgba(12, 148, 136, 0.18), transparent 58%),
      radial-gradient(900px 380px at 88% 0%, rgba(245, 158, 11, 0.12), transparent 58%),
      linear-gradient(180deg, #fbfaf6 0%, #f3f5f8 52%, #eef2f5 100%);
  }

  .page-service-request .container {
    max-width: 980px;
  }

  .page-service-request .auth-gate-unified {
    max-width: 540px;
    margin: 0 auto 24px;
    border-radius: 32px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.9);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.12);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .page-service-request .sr-stage {
    --sr-accent: #0f766e;
    --sr-accent-strong: #115e59;
    --sr-accent-soft: rgba(15, 118, 110, 0.12);
    --sr-accent-glow: rgba(15, 118, 110, 0.18);
    --sr-border: rgba(15, 23, 42, 0.08);
    --sr-surface: rgba(255, 255, 255, 0.8);
    --sr-surface-strong: rgba(255, 255, 255, 0.94);
    position: relative;
    display: grid;
    gap: 16px;
  }

  .page-service-request .sr-stage[data-request-mode="competitive"] {
    --sr-accent: #1d4ed8;
    --sr-accent-strong: #1e40af;
    --sr-accent-soft: rgba(29, 78, 216, 0.12);
    --sr-accent-glow: rgba(29, 78, 216, 0.18);
  }

  .page-service-request .sr-stage[data-request-mode="urgent"] {
    --sr-accent: #c2410c;
    --sr-accent-strong: #9a3412;
    --sr-accent-soft: rgba(194, 65, 12, 0.12);
    --sr-accent-glow: rgba(194, 65, 12, 0.18);
  }

  .page-service-request .sr-stage[data-request-mode="provider_direct"] {
    --sr-accent: #166534;
    --sr-accent-strong: #14532d;
    --sr-accent-soft: rgba(22, 101, 52, 0.12);
    --sr-accent-glow: rgba(22, 101, 52, 0.18);
  }

  .page-service-request .sr-hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .page-service-request .sr-hero-main,
  .page-service-request .sr-form,
  .page-service-request .sr-success-card {
    border: 1px solid var(--sr-border);
    background: var(--sr-surface);
    box-shadow: 0 24px 60px rgba(15, 23, 42, 0.08);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
  }

  .page-service-request .sr-hero-main {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    padding: 18px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.95), rgba(246, 249, 250, 0.88)),
      radial-gradient(circle at top right, var(--sr-accent-soft), transparent 42%);
  }

  .page-service-request .sr-hero-main::before,
  .page-service-request .sr-hero-main::after {
    content: "";
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
  }

  .page-service-request .sr-hero-main::before {
    width: 240px;
    height: 240px;
    inset-inline-end: -76px;
    top: -72px;
    background: radial-gradient(circle, var(--sr-accent-glow) 0%, transparent 66%);
  }

  .page-service-request .sr-hero-main::after {
    width: 180px;
    height: 180px;
    inset-inline-start: -48px;
    bottom: -68px;
    background: radial-gradient(circle, rgba(245, 158, 11, 0.14) 0%, transparent 66%);
  }

  .page-service-request .sr-hero-topbar {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .page-service-request .sr-back {
    width: 48px;
    height: 48px;
    border-radius: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.82);
    color: #0f172a;
    text-decoration: none;
    box-shadow: 0 10px 20px rgba(15, 23, 42, 0.05);
  }

  .page-service-request .sr-head-copy {
    min-width: 0;
    display: grid;
    gap: 4px;
  }

  .page-service-request .sr-kicker,
  .page-service-request .sr-chip-badge,
  .page-service-request .sr-guide-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: fit-content;
    min-height: 28px;
    padding: 0 12px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--sr-accent) 18%, white);
    background: color-mix(in srgb, var(--sr-accent) 10%, white);
    color: var(--sr-accent-strong);
    font-size: 10.5px;
    font-weight: 900;
    letter-spacing: 0.02em;
  }

  .page-service-request #sr-title {
    margin: 0;
    font-size: clamp(1.35rem, 1.8vw, 1.7rem);
    line-height: 1.2;
    color: #0f172a;
    font-weight: 900;
  }

  .page-service-request .sr-head-orb {
    margin-inline-start: auto;
    width: 46px;
    height: 46px;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--sr-accent), var(--sr-accent-strong));
    color: #fff;
    box-shadow: 0 16px 32px var(--sr-accent-glow);
    flex: 0 0 auto;
  }

  .page-service-request .sr-hero-copy {
    position: relative;
    z-index: 1;
    display: grid;
    gap: 8px;
    margin-top: 14px;
  }

  .page-service-request .sr-request-kind-title {
    margin: 0;
    color: #0f172a;
    font-size: clamp(1.05rem, 1.4vw, 1.2rem);
    line-height: 1.5;
    font-weight: 900;
  }

  .page-service-request .sr-subtitle,
  .page-service-request .sr-request-kind-text,
  .page-service-request .sr-section-head p,
  .page-service-request .sr-helper,
  .page-service-request .char-count,
  .page-service-request .sr-map-head-copy span,
  .page-service-request .sr-map-coords,
  .page-service-request .sr-fixed-meta,
  .page-service-request .sr-fixed-item span {
    margin: 0;
    color: #5b6578;
    font-size: 11px;
    line-height: 1.8;
    font-weight: 700;
  }
  .page-service-request .sr-layout {
    display: block;
  }

  .page-service-request .sr-main {
    min-width: 0;
  }

  .page-service-request .sr-form {
    max-width: 860px;
    margin: 0 auto;
    border-radius: 28px;
    padding: 18px;
  }

  .page-service-request .sr-grid {
    display: grid;
    gap: 16px;
  }

  .page-service-request .sr-section {
    position: relative;
    overflow: hidden;
    border-radius: 28px;
    border: 1px solid rgba(15, 23, 42, 0.06);
    background: var(--sr-surface-strong);
    padding: 18px;
    animation: srLift 0.45s ease both;
  }

  .page-service-request .sr-section:nth-child(2) {
    animation-delay: 0.05s;
  }

  .page-service-request .sr-section:nth-child(3) {
    animation-delay: 0.1s;
  }

  .page-service-request .sr-section:nth-child(4) {
    animation-delay: 0.15s;
  }

  @keyframes srLift {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .page-service-request .sr-section::before {
    content: "";
    position: absolute;
    inset-inline: 0;
    top: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--sr-accent), color-mix(in srgb, var(--sr-accent) 55%, white));
  }

  .page-service-request .sr-section-head {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 16px;
  }

  .page-service-request .sr-section-step {
    width: 34px;
    height: 34px;
    border-radius: 14px;
    background: color-mix(in srgb, var(--sr-accent) 14%, white);
    color: var(--sr-accent-strong);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 13px;
    font-weight: 900;
    flex: 0 0 auto;
  }

  .page-service-request .sr-section-head h2,
  .page-service-request .sr-map-head-copy strong,
  .page-service-request .sr-fixed-head-copy strong,
  .page-service-request .sr-upload-trigger strong {
    margin: 0;
    color: #0f172a;
    font-size: 16px;
    line-height: 1.5;
    font-weight: 900;
  }

  .page-service-request .sr-fields-grid {
    display: grid;
    gap: 14px;
  }

  .page-service-request .sr-fields-grid-two {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .page-service-request .sr-group {
    margin: 0;
  }

  .page-service-request .sr-label {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-bottom: 8px;
    color: #172033;
    font-size: 12.5px;
    font-weight: 900;
  }

  .page-service-request .sr-required {
    color: #d92d20;
  }

  .page-service-request .sr-form .form-input,
  .page-service-request .sr-form .form-select,
  .page-service-request .sr-form .form-textarea {
    width: 100%;
    min-height: 52px;
    padding: 13px 14px;
    border-radius: 18px;
    border: 1px solid rgba(15, 23, 42, 0.1);
    background: rgba(248, 250, 252, 0.88);
    color: #0f172a;
    font-family: "Cairo", sans-serif;
    font-size: 13px;
    line-height: 1.6;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, background-color 0.18s ease, transform 0.18s ease;
  }

  .page-service-request .sr-form .form-textarea {
    min-height: 170px;
    resize: vertical;
  }

  .page-service-request .sr-form .form-input:focus,
  .page-service-request .sr-form .form-select:focus,
  .page-service-request .sr-form .form-textarea:focus {
    outline: none;
    background: #fff;
    border-color: color-mix(in srgb, var(--sr-accent) 55%, white);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--sr-accent) 14%, white);
    transform: translateY(-1px);
  }

  .page-service-request .sr-form .is-invalid {
    border-color: #e11d48 !important;
    box-shadow: 0 0 0 4px rgba(225, 29, 72, 0.12);
  }

  .page-service-request .sr-field-error {
    display: block;
    margin-top: 6px;
    color: #be123c;
    font-size: 11px;
    line-height: 1.75;
    font-weight: 800;
  }

  .page-service-request .sr-type-chips,
  .page-service-request .sr-dispatch-chips,
  .page-service-request .sr-city-toggle-chips,
  .page-service-request .attach-btns {
    display: grid;
    gap: 12px;
  }

  .page-service-request .sr-type-chips {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .page-service-request .sr-type-chips .chip,
  .page-service-request .sr-dispatch-chip,
  .page-service-request .sr-city-toggle-chip,
  .page-service-request .sr-upload-trigger {
    position: relative;
    overflow: hidden;
    cursor: pointer;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(246, 249, 251, 0.9));
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s ease;
  }

  .page-service-request .sr-type-chips .chip {
    min-height: 144px;
    padding: 16px;
    border-radius: 24px;
    text-align: start;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
    color: #0f172a;
  }

  .page-service-request .sr-type-chips .chip strong,
  .page-service-request .sr-dispatch-chip .sr-dispatch-chip-title {
    color: #0f172a;
    font-size: 14px;
    line-height: 1.55;
    font-weight: 900;
  }

  .page-service-request .sr-type-chips .chip span,
  .page-service-request .sr-dispatch-chip .sr-dispatch-chip-desc,
  .page-service-request .sr-city-toggle-chip small {
    color: #5b6578;
    font-size: 11px;
    line-height: 1.8;
    font-weight: 700;
  }

  .page-service-request .sr-type-chips .chip::after,
  .page-service-request .sr-dispatch-chip::after,
  .page-service-request .sr-city-toggle-chip::after,
  .page-service-request .sr-upload-trigger::after {
    content: "";
    position: absolute;
    inset-inline-end: -24px;
    bottom: -24px;
    width: 96px;
    height: 96px;
    border-radius: 50%;
    background: radial-gradient(circle, var(--sr-accent-soft) 0%, transparent 66%);
    opacity: 0;
    transition: opacity 0.18s ease;
    pointer-events: none;
  }

  .page-service-request .sr-type-chips .chip:hover,
  .page-service-request .sr-type-chips .chip.active,
  .page-service-request .sr-dispatch-chip:hover,
  .page-service-request .sr-dispatch-chip.active,
  .page-service-request .sr-city-toggle-chip:hover,
  .page-service-request .sr-city-toggle-chip.active,
  .page-service-request .sr-upload-trigger:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--sr-accent) 28%, white);
    box-shadow: 0 16px 32px var(--sr-accent-soft);
  }

  .page-service-request .sr-type-chips .chip:hover::after,
  .page-service-request .sr-type-chips .chip.active::after,
  .page-service-request .sr-dispatch-chip:hover::after,
  .page-service-request .sr-dispatch-chip.active::after,
  .page-service-request .sr-city-toggle-chip:hover::after,
  .page-service-request .sr-city-toggle-chip.active::after,
  .page-service-request .sr-upload-trigger:hover::after {
    opacity: 1;
  }

  .page-service-request .sr-type-chips .chip.active,
  .page-service-request .sr-dispatch-chip.active,
  .page-service-request .sr-city-toggle-chip.active {
    background: linear-gradient(145deg, color-mix(in srgb, var(--sr-accent) 12%, white), rgba(255, 255, 255, 0.96));
  }

  .page-service-request .sr-dispatch-chip {
    min-height: 108px;
    padding: 16px;
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    gap: 8px;
    text-align: start;
  }

  .page-service-request .sr-dispatch-chip .sr-dispatch-chip-icon,
  .page-service-request .sr-upload-icon,
  .page-service-request .sr-fixed-icon,
  .page-service-request .sr-map-head-icon {
    width: 40px;
    height: 40px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: color-mix(in srgb, var(--sr-accent) 14%, white);
    color: var(--sr-accent-strong);
    flex: 0 0 auto;
  }

  .page-service-request .sr-dispatch-section,
  .page-service-request .sr-map-wrap,
  .page-service-request .sr-city-toggle-wrap {
    animation: srLift 0.28s ease both;
  }

  .page-service-request .sr-dispatch-label,
  .page-service-request .sr-city-toggle-label {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
    color: #172033;
    font-size: 12.5px;
    font-weight: 900;
  }

  .page-service-request .sr-dispatch-chips,
  .page-service-request .sr-city-toggle-chips,
  .page-service-request .attach-btns {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .page-service-request .sr-city-toggle-chip {
    padding: 14px;
    border-radius: 20px;
    text-align: start;
    display: flex;
    flex-direction: column;
    gap: 4px;
    color: #0f172a;
    font-size: 12px;
    font-weight: 900;
  }

  .page-service-request .sr-map-wrap {
    overflow: hidden;
    border-radius: 24px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.96);
  }

  .page-service-request .sr-map-head,
  .page-service-request .sr-map-footer {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px;
  }

  .page-service-request .sr-map-head {
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
  }

  .page-service-request .sr-map-status {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    padding: 0 10px;
    border-radius: 999px;
    border: 1px solid rgba(15, 118, 110, 0.18);
    background: rgba(15, 118, 110, 0.08);
    color: #166534;
    font-size: 10px;
    font-weight: 900;
  }

  .page-service-request .sr-map-status.loading {
    border-color: rgba(245, 158, 11, 0.22);
    background: rgba(245, 158, 11, 0.1);
    color: #a16207;
  }

  .page-service-request .sr-map-status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: currentColor;
    animation: srPulse 1.2s ease-in-out infinite;
  }

  @keyframes srPulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.35;
    }
  }

  .page-service-request .sr-map-canvas {
    height: 300px;
    background: #e7ecef;
  }

  .page-service-request .sr-map-footer {
    border-top: 1px solid rgba(15, 23, 42, 0.06);
    flex-wrap: wrap;
  }

  .page-service-request .sr-map-recenter,
  .page-service-request .city-clear-btn {
    width: fit-content;
    border: 0;
    border-radius: 14px;
    padding: 10px 14px;
    background: color-mix(in srgb, var(--sr-accent) 11%, white);
    color: var(--sr-accent-strong);
    font-size: 11px;
    line-height: 1.4;
    font-weight: 900;
    cursor: pointer;
    text-decoration: none;
  }

  .page-service-request .sr-map-recenter {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .page-service-request .sr-fixed-target {
    overflow: hidden;
    border-radius: 26px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.98);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.82);
  }

  .page-service-request .sr-fixed-target-head {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 18px;
    border-bottom: 1px solid rgba(15, 23, 42, 0.06);
    background: linear-gradient(145deg, color-mix(in srgb, var(--sr-accent) 8%, white), rgba(255, 255, 255, 0.94));
  }

  .page-service-request .sr-fixed-target-badge {
    margin-inline-start: auto;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    min-height: 28px;
    padding: 0 12px;
    border-radius: 999px;
    background: color-mix(in srgb, var(--sr-accent) 12%, white);
    color: var(--sr-accent-strong);
    font-size: 10.5px;
    font-weight: 900;
    border: 1px solid color-mix(in srgb, var(--sr-accent) 18%, white);
  }

  .page-service-request .sr-fixed-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1px;
    background: rgba(15, 23, 42, 0.05);
  }

  .page-service-request .sr-fixed-item {
    display: grid;
    gap: 6px;
    padding: 18px;
    background: rgba(255, 255, 255, 0.98);
  }

  .page-service-request .sr-fixed-item:last-child:nth-child(odd) {
    grid-column: 1 / -1;
  }

  .page-service-request .sr-fixed-item strong {
    color: #0f172a;
    font-size: 14px;
    line-height: 1.7;
    font-weight: 900;
    word-break: break-word;
  }

  .page-service-request .sr-attachments-wrap {
    border-radius: 26px;
    border: 1px dashed color-mix(in srgb, var(--sr-accent) 26%, white);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.95), rgba(243, 247, 248, 0.88)),
      radial-gradient(circle at top right, var(--sr-accent-soft), transparent 48%);
    padding: 16px;
  }

  .page-service-request .attachments-preview {
    display: grid;
    gap: 10px;
    margin-bottom: 12px;
  }

  .page-service-request .sr-upload-trigger {
    min-height: 92px;
    border-radius: 22px;
    padding: 14px;
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    color: inherit;
  }

  .page-service-request .sr-upload-copy {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .page-service-request .sr-upload-copy span {
    color: #5b6578;
    font-size: 11px;
    line-height: 1.7;
    font-weight: 700;
  }

  .page-service-request .sr-attachment-note {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-top: 12px;
    padding: 12px 14px;
    border-radius: 18px;
    border: 1px solid rgba(22, 101, 52, 0.16);
    background: rgba(22, 101, 52, 0.07);
    color: #166534;
  }

  .page-service-request .sr-attachment-note strong {
    display: block;
    color: #14532d;
    font-size: 11.5px;
    line-height: 1.65;
    font-weight: 900;
  }

  .page-service-request .sr-attachment-note span {
    color: #166534;
    font-size: 11px;
    line-height: 1.75;
    font-weight: 700;
  }

  .page-service-request .sr-attachment-note-icon {
    width: 32px;
    height: 32px;
    border-radius: 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #166534, #16a34a);
    color: #fff;
    box-shadow: 0 12px 22px rgba(22, 101, 52, 0.18);
    flex: 0 0 auto;
  }

  .page-service-request .sr-attachment-note.hidden {
    display: none;
  }

  .page-service-request .attach-item {
    position: relative;
    overflow: hidden;
    border-radius: 20px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background: rgba(255, 255, 255, 0.96);
    box-shadow: 0 14px 28px rgba(15, 23, 42, 0.06);
  }

  .page-service-request .attach-item img {
    width: 100%;
    max-height: 220px;
    object-fit: cover;
  }

  .page-service-request .attach-item.file-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
  }

  .page-service-request .attach-item.file-item span {
    min-width: 0;
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    color: #0f172a;
    font-size: 11.5px;
    font-weight: 800;
  }

  .page-service-request .attach-remove {
    position: absolute;
    top: 10px;
    left: 10px;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    border: 0;
    background: rgba(15, 23, 42, 0.72);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: 900;
    cursor: pointer;
  }

  .page-service-request .attach-item.file-item .attach-remove {
    position: static;
    background: rgba(220, 38, 38, 0.1);
    color: #dc2626;
  }

  .page-service-request .sr-actions {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: 12px;
    margin-top: 18px;
    padding: 14px;
    border-radius: 28px;
    border: 1px solid rgba(15, 23, 42, 0.06);
    background: rgba(248, 250, 252, 0.9);
  }

  .page-service-request .sr-cancel-btn,
  .page-service-request .sr-submit-btn {
    min-height: 60px;
    width: 100%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 0 18px;
    border-radius: 22px;
    text-decoration: none;
    font-size: 13px;
    font-weight: 900;
    transition: transform 0.18s ease, box-shadow 0.18s ease, filter 0.18s ease;
  }

  .page-service-request .sr-cancel-btn {
    border: 1px solid rgba(15, 23, 42, 0.1);
    background: rgba(255, 255, 255, 0.94);
    color: #172033;
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.05);
  }

  .page-service-request .sr-submit-btn {
    border: 0;
    color: #fff;
    background: linear-gradient(135deg, var(--sr-accent), var(--sr-accent-strong));
    box-shadow: 0 18px 34px var(--sr-accent-glow);
  }

  .page-service-request .sr-cancel-btn:hover,
  .page-service-request .sr-submit-btn:hover {
    transform: translateY(-1px);
  }

  .page-service-request .sr-cancel-btn:disabled,
  .page-service-request .sr-submit-btn:disabled {
    cursor: not-allowed;
    filter: saturate(0.9);
  }

  .page-service-request .sr-cancel-btn-icon,
  .page-service-request .sr-submit-btn-icon {
    width: 38px;
    height: 38px;
    border-radius: 14px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex: 0 0 auto;
  }

  .page-service-request .sr-cancel-btn-icon {
    background: rgba(15, 23, 42, 0.06);
  }

  .page-service-request .sr-submit-btn-icon {
    background: rgba(255, 255, 255, 0.14);
  }

  .page-service-request .sr-action-copy {
    display: grid;
    gap: 2px;
    text-align: start;
  }

  .page-service-request .sr-action-copy small {
    font-size: 10.5px;
    line-height: 1.5;
    font-weight: 700;
    opacity: 0.88;
  }

  .page-service-request .sr-toast {
    position: fixed;
    inset-inline: 12px;
    bottom: calc(var(--bottom-nav-height, 84px) + 16px);
    z-index: 220;
    width: min(560px, calc(100vw - 24px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 12px;
    align-items: start;
    padding: 15px 16px 18px;
    border-radius: 26px;
    border: 1px solid rgba(15, 23, 42, 0.08);
    background:
      linear-gradient(150deg, rgba(255, 255, 255, 0.96), rgba(246, 249, 252, 0.94)),
      radial-gradient(circle at top right, var(--sr-accent-soft), transparent 40%);
    box-shadow: 0 26px 58px rgba(15, 23, 42, 0.18);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    overflow: hidden;
    opacity: 0;
    transform: translateY(18px) scale(0.98);
    pointer-events: none;
    transition: opacity 0.24s ease, transform 0.24s ease;
  }

  .page-service-request .sr-toast.show {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .page-service-request .sr-toast.success {
    border-color: rgba(22, 101, 52, 0.18);
    background: linear-gradient(145deg, rgba(248, 255, 250, 0.98), rgba(237, 252, 242, 0.95));
  }

  .page-service-request .sr-toast.warning {
    border-color: rgba(245, 158, 11, 0.24);
    background: linear-gradient(145deg, rgba(255, 252, 245, 0.98), rgba(255, 246, 228, 0.95));
  }

  .page-service-request .sr-toast.error {
    border-color: rgba(190, 24, 93, 0.2);
    background: linear-gradient(145deg, rgba(255, 249, 251, 0.98), rgba(255, 239, 243, 0.95));
  }

  .page-service-request .sr-toast-icon {
    width: 44px;
    height: 44px;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    background: linear-gradient(135deg, var(--sr-accent), var(--sr-accent-strong));
    box-shadow: 0 12px 24px var(--sr-accent-glow);
  }

  .page-service-request .sr-toast.warning .sr-toast-icon {
    background: linear-gradient(135deg, #d97706, #f59e0b);
  }

  .page-service-request .sr-toast.error .sr-toast-icon {
    background: linear-gradient(135deg, #be185d, #e11d48);
  }

  .page-service-request .sr-toast-copy {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .page-service-request .sr-toast-copy strong {
    color: #0f172a;
    font-size: 14px;
    font-weight: 900;
  }

  .page-service-request .sr-toast-copy p {
    margin: 0;
    color: #475569;
    font-size: 13px;
    line-height: 1.8;
    font-weight: 700;
    white-space: pre-line;
  }

  .page-service-request .sr-toast-close {
    width: 36px;
    height: 36px;
    border: 0;
    border-radius: 12px;
    background: rgba(15, 23, 42, 0.06);
    color: #0f172a;
    cursor: pointer;
  }

  .page-service-request .sr-toast-progress {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--sr-accent), color-mix(in srgb, var(--sr-accent) 45%, white));
    transform-origin: right center;
    transform: scaleX(0);
  }

  .page-service-request .sr-toast.show .sr-toast-progress {
    animation: srToastTimer 4.6s linear forwards;
  }

  @keyframes srToastTimer {
    from {
      transform: scaleX(1);
    }
    to {
      transform: scaleX(0);
    }
  }

  .page-service-request .sr-success-card {
    max-width: 480px;
    border-radius: 34px;
    padding: 28px;
    background:
      linear-gradient(150deg, rgba(255, 255, 255, 0.98), rgba(246, 250, 247, 0.96)),
      radial-gradient(circle at top right, rgba(22, 101, 52, 0.12), transparent 42%);
  }

  .page-service-request .sr-success-card p {
    margin-bottom: 0;
  }

  @media (max-width: 768px) {
    .page-service-request .sr-hero-main,
    .page-service-request .sr-form {
      border-radius: 26px;
    }

    .page-service-request .sr-hero-main,
    .page-service-request .sr-form,
    .page-service-request .sr-section {
      padding: 18px;
    }

    .page-service-request .sr-fields-grid-two,
    .page-service-request .sr-type-chips,
    .page-service-request .sr-fixed-grid,
    .page-service-request .sr-dispatch-chips,
    .page-service-request .sr-city-toggle-chips,
    .page-service-request .attach-btns,
    .page-service-request .sr-actions {
      grid-template-columns: 1fr;
    }

    .page-service-request .sr-fixed-item:last-child:nth-child(odd) {
      grid-column: auto;
    }

    .page-service-request .sr-hero-topbar {
      flex-wrap: wrap;
    }

    .page-service-request .sr-head-orb {
      margin-inline-start: 0;
    }

    .page-service-request .sr-toast {
      grid-template-columns: auto 1fr;
      padding: 14px 14px 18px;
    }

    .page-service-request .sr-toast-close {
      grid-column: 2;
      justify-self: end;
      margin-top: -4px;
    }
  }

  /* ── Inline Map Picker (nearest provider) ────────────── */
  .page-service-request .sr-map-inline-panel {
    position: relative;
    width: 100%;
    border-radius: 0;
    background: #fff;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .page-service-request .sr-map-modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 20px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    flex: 0 0 auto;
  }

  .page-service-request .sr-map-modal-header h3 {
    margin: 0;
    font-size: 15px;
    font-weight: 900;
    color: #1f1b32;
  }

  .page-service-request .sr-map-inline-refresh {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 0;
    background: rgba(15, 23, 42, 0.06);
    color: #444;
    font-size: 20px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .page-service-request .sr-map-inline-refresh:hover {
    background: rgba(15, 23, 42, 0.12);
  }

  .page-service-request .sr-modal-map-canvas {
    width: 100%;
    height: 46vh;
    min-height: 260px;
    background: #eef0f8;
    flex: 0 0 auto;
  }

  .page-service-request .sr-modal-status-bar {
    padding: 10px 20px;
    font-size: 12px;
    font-weight: 700;
    color: #6b6780;
    display: flex;
    align-items: center;
    gap: 8px;
    border-bottom: 1px solid rgba(0, 0, 0, 0.05);
    flex: 0 0 auto;
  }

  .page-service-request .sr-modal-status-bar .sr-modal-status-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #f59e0b;
    animation: srPulse 1.4s ease-in-out infinite;
  }

  .page-service-request .sr-modal-status-bar.ready .sr-modal-status-dot {
    background: #22c55e;
    animation: none;
  }

  .page-service-request .sr-modal-providers-list {
    flex: 1 1 auto;
    overflow-y: auto;
    max-height: 30vh;
    padding: 12px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .page-service-request .sr-modal-provider-card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px;
    border-radius: 16px;
    border: 1.5px solid rgba(103, 58, 183, 0.1);
    background: #fff;
    cursor: pointer;
    transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
  }

  .page-service-request .sr-modal-provider-card:hover {
    border-color: rgba(103, 58, 183, 0.22);
    box-shadow: 0 4px 14px rgba(103, 58, 183, 0.08);
  }

  .page-service-request .sr-modal-provider-card.selected {
    border-color: rgba(103, 58, 183, 0.5);
    background: rgba(103, 58, 183, 0.04);
    box-shadow: 0 6px 18px rgba(103, 58, 183, 0.12);
  }

  .page-service-request .sr-modal-provider-avatar {
    width: 46px;
    height: 46px;
    border-radius: 14px;
    object-fit: cover;
    flex: 0 0 auto;
    background: #eee;
  }

  .page-service-request .sr-modal-provider-info {
    flex: 1;
    min-width: 0;
    display: grid;
    gap: 2px;
  }

  .page-service-request .sr-modal-provider-name {
    font-size: 13px;
    font-weight: 800;
    color: #1f1b32;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .page-service-request .sr-modal-provider-meta {
    font-size: 11px;
    font-weight: 700;
    color: #7a748f;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .page-service-request .sr-modal-provider-check {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 2px solid rgba(103, 58, 183, 0.2);
    background: #fff;
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.18s ease;
  }

  .page-service-request .sr-modal-provider-card.selected .sr-modal-provider-check {
    border-color: #6f42c1;
    background: linear-gradient(135deg, #6f42c1, #a78bfa);
    color: #fff;
  }

  .page-service-request .sr-modal-confirm-bar {
    padding: 14px 20px;
    border-top: 1px solid rgba(0, 0, 0, 0.06);
    display: flex;
    align-items: center;
    gap: 12px;
    flex: 0 0 auto;
  }

  .page-service-request .sr-modal-confirm-btn {
    flex: 1;
    min-height: 48px;
    border: 0;
    border-radius: 16px;
    background: linear-gradient(135deg, #6f42c1, #5b36ab);
    color: #fff;
    font-size: 14px;
    font-weight: 900;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
    box-shadow: 0 8px 20px rgba(111, 66, 193, 0.25);
  }

  .page-service-request .sr-modal-confirm-btn:hover {
    transform: translateY(-1px);
  }

  .page-service-request .sr-modal-confirm-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
    transform: none;
  }

  /* ── Selected Provider Card (shown after picking from modal) ── */
  .page-service-request .sr-selected-provider {
    margin-top: 12px;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px;
    border-radius: 18px;
    border: 1.5px solid rgba(103, 58, 183, 0.3);
    background: linear-gradient(135deg, rgba(103, 58, 183, 0.06), rgba(103, 58, 183, 0.02));
    animation: srFadeSlideIn 0.3s ease both;
  }

  .page-service-request .sr-selected-provider-avatar {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    object-fit: cover;
    flex: 0 0 auto;
    background: #eee;
    border: 2px solid rgba(103, 58, 183, 0.2);
  }

  .page-service-request .sr-selected-provider-info {
    flex: 1;
    min-width: 0;
    display: grid;
    gap: 3px;
  }

  .page-service-request .sr-selected-provider-info strong {
    font-size: 13px;
    font-weight: 900;
    color: #1f1b32;
  }

  .page-service-request .sr-selected-provider-info span {
    font-size: 11px;
    font-weight: 700;
    color: #6f42c1;
  }

  .page-service-request .sr-selected-provider-actions {
    display: flex;
    gap: 6px;
    flex: 0 0 auto;
  }

  .page-service-request .sr-selected-provider-change,
  .page-service-request .sr-selected-provider-remove {
    width: 34px;
    height: 34px;
    border-radius: 10px;
    border: 1px solid rgba(103, 58, 183, 0.14);
    background: #fff;
    color: #6f42c1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.15s;
  }

  .page-service-request .sr-selected-provider-remove {
    color: #dc2626;
    border-color: rgba(220, 38, 38, 0.14);
  }

  .page-service-request .sr-selected-provider-change:hover {
    background: rgba(103, 58, 183, 0.08);
  }

  .page-service-request .sr-selected-provider-remove:hover {
    background: rgba(220, 38, 38, 0.08);
  }

  .page-service-request .sr-modal-empty {
    text-align: center;
    padding: 32px 16px;
    color: #7a748f;
    font-size: 13px;
    font-weight: 700;
  }
</style>
{% endblock %}

{% block content %}
<main class="page-content">
  <div class="container">
    <div id="auth-gate" class="auth-gate auth-gate-unified hidden">
      <div class="auth-gate-unified-icon" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <rect x="3" y="11" width="18" height="11" rx="2"></rect>
          <path d="M7 11V7a5 5 0 0110 0v4"></path>
        </svg>
      </div>
      <h2 class="auth-gate-unified-title">سجّل دخولك لإرسال الطلب</h2>
      <p class="auth-gate-unified-desc">سيتم حفظ الطلب وربطه بحسابك حتى تتابع حالته، الرسائل، والعروض أو التوجيهات المرتبطة به لاحقاً.</p>
      <a href="/login/" id="sr-login-link" class="btn btn-primary auth-gate-unified-btn">تسجيل الدخول</a>
    </div>

    <div id="form-content" class="hidden sr-stage" data-request-mode="normal">
      <section class="sr-hero" aria-label="مقدمة الطلب">
        <div class="sr-hero-main">
          <div class="sr-hero-topbar">
            <a href="javascript:history.back()" class="sr-back" aria-label="رجوع">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M15.41 7.41 14 6l-6 6 6 6 1.41-1.41L10.83 12z"/></svg>
            </a>
            <div class="sr-head-copy">
              <span id="sr-request-kind-label" class="sr-kicker">المسار الحالي</span>
              <h1 id="sr-title">طلب خدمة جديدة</h1>
            </div>
            <span class="sr-head-orb" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 5v14"/><path d="M5 12h14"/></svg>
            </span>
          </div>

          <div class="sr-hero-copy">
            <h2 id="sr-request-kind-title" class="sr-request-kind-title">اختر المسار الأنسب ثم ابدأ كتابة الطلب</h2>
            <p id="sr-request-kind-text" class="sr-request-kind-text">واجهة مباشرة ومختصرة: اختر النوع، عبّئ الحقول الأساسية، ثم أرسل الطلب.</p>
          </div>
          <p class="sr-subtitle">نموذج تنفيذ مباشر بدون بطاقات شرح إضافية.</p>
        </div>
      </section>

      <div class="sr-layout">
        <div class="sr-main">
          <form id="sr-form" class="sr-form" autocomplete="off">
            <div class="sr-grid">
              <section id="sr-type-section" class="sr-section">
                <div class="sr-section-head">
                  <span class="sr-section-step">1</span>
                  <div>
                    <h2>اختر المسار التشغيلي</h2>
                    <p>حدد نوع الطلب فقط، وستظهر الحقول المرتبطة به.</p>
                  </div>
                </div>

                <div class="sr-type-chips" id="sr-type-chips">
                  <button type="button" class="chip active" data-val="normal">
                    <span class="sr-chip-badge">حصري</span>
                    <strong>طلب مباشر</strong>
                    <span>للتوجيه إلى مزود محدد فقط مع متابعة تنفيذية مباشرة.</span>
                  </button>
                  <button type="button" class="chip" data-val="competitive">
                    <span class="sr-chip-badge">عروض</span>
                    <strong>طلب تنافسي</strong>
                    <span>لفتح المجال لأكثر من عرض سعر ضمن تصنيف ونطاق واضحين.</span>
                  </button>
                  <button type="button" class="chip" data-val="urgent">
                    <span class="sr-chip-badge">سريع</span>
                    <strong>طلب عاجل</strong>
                    <span>للتوجيه السريع إلى المؤهلين أو الأقرب حسب الموقع الجغرافي.</span>
                  </button>
                </div>
              </section>

              <section class="sr-section">
                <div class="sr-section-head">
                  <span class="sr-section-step">2</span>
                  <div>
                    <h2 id="sr-scope-title">التصنيف والنطاق</h2>
                    <p id="sr-scope-text">اختر القسم والتصنيف والمدينة عند الحاجة.</p>
                  </div>
                </div>

                <div id="sr-fixed-target" class="sr-fixed-target hidden" aria-live="polite">
                  <div class="sr-fixed-target-head">
                    <span class="sr-fixed-icon" aria-hidden="true">
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </span>
                    <div class="sr-fixed-head-copy">
                      <strong>بيانات مزود الخدمة المحدد</strong>
                      <p class="sr-fixed-meta">تمت مزامنة هذا الجزء مع صفحة المزود أو الخدمة التي بدأت منها.</p>
                    </div>
                    <span class="sr-fixed-target-badge">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg>
                      مباشر
                    </span>
                  </div>
                  <div class="sr-fixed-grid">
                    <div class="sr-fixed-item">
                      <span>مزود الخدمة</span>
                      <strong id="sr-fixed-provider-name">-</strong>
                    </div>
                    <div id="sr-fixed-service-row" class="sr-fixed-item hidden">
                      <span>الخدمة</span>
                      <strong id="sr-fixed-service">-</strong>
                    </div>
                    <div class="sr-fixed-item">
                      <span>القسم</span>
                      <strong id="sr-fixed-category">-</strong>
                    </div>
                    <div class="sr-fixed-item">
                      <span>التصنيف</span>
                      <strong id="sr-fixed-subcategory">-</strong>
                    </div>
                    <div class="sr-fixed-item">
                      <span>المنطقة الإدارية - المدينة</span>
                      <strong id="sr-fixed-city">-</strong>
                    </div>
                  </div>
                </div>

                <div id="sr-scope-fields" class="sr-fields-grid sr-fields-grid-two">
                  <div class="form-group sr-group">
                    <label class="form-label sr-label" for="sr-category">القسم <span class="sr-required">*</span></label>
                    <select id="sr-category" class="form-select" required aria-describedby="sr-category-error"><option value="">اختر القسم</option></select>
                    <small id="sr-category-error" class="sr-field-error hidden" role="alert"></small>
                  </div>

                  <div class="form-group sr-group">
                    <label class="form-label sr-label" for="sr-subcategory">التصنيف الفرعي <span class="sr-required">*</span></label>
                    <select id="sr-subcategory" class="form-select" required aria-describedby="sr-subcategory-error"><option value="">اختر التصنيف</option></select>
                    <small id="sr-subcategory-error" class="sr-field-error hidden" role="alert"></small>
                  </div>

                  <div class="form-group sr-group" id="sr-region-group">
                    <label class="form-label sr-label" for="sr-region">المنطقة الإدارية</label>
                    <select id="sr-region" class="form-select">
                      <option value="">اختر المنطقة الإدارية</option>
                    </select>
                  </div>

                  <div class="form-group sr-group" id="sr-city-group">
                    <label class="form-label sr-label" for="sr-city">المدينة</label>
                    <select id="sr-city" class="form-select" aria-describedby="sr-city-error">
                      <option value="">اختر المنطقة أولًا ثم المدينة (اختياري)</option>
                    </select>
                    <small id="sr-city-error" class="sr-field-error hidden" role="alert"></small>
                    <button type="button" id="sr-city-clear" class="city-clear-btn hidden">إلغاء اختيار المدينة</button>
                  </div>

                  <div class="form-group sr-group hidden" id="sr-deadline-group">
                    <label class="form-label sr-label" id="sr-deadline-label" for="sr-deadline">آخر موعد لاستلام العروض</label>
                    <input id="sr-deadline" type="date" class="form-input" aria-describedby="sr-deadline-error">
                    <small id="sr-deadline-error" class="sr-field-error hidden" role="alert"></small>
                    <p class="sr-helper" id="sr-deadline-hint">اختياري.</p>
                  </div>

                  <div id="sr-dispatch-section" class="sr-dispatch-section hidden" style="grid-column:1/-1">
                    <label class="sr-dispatch-label">طريقة توجيه الطلب العاجل</label>
                    <div class="sr-dispatch-chips" id="sr-dispatch-chips">
                      <button type="button" class="sr-dispatch-chip active" data-dispatch="all">
                        <span class="sr-dispatch-chip-icon" aria-hidden="true">
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                        </span>
                        <span class="sr-dispatch-chip-title">الإرسال للجميع</span>
                        <span class="sr-dispatch-chip-desc">يبث الطلب لكل مزود مؤهل ضمن التخصص والنطاق المختار.</span>
                      </button>
                      <button type="button" class="sr-dispatch-chip" data-dispatch="nearest">
                        <span class="sr-dispatch-chip-icon" aria-hidden="true">
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        </span>
                        <span class="sr-dispatch-chip-title">البحث عن الأقرب</span>
                        <span class="sr-dispatch-chip-desc">يستخدم موقعك الحالي لانتقاء المزودين الأقرب والأسرع وصولاً.</span>
                      </button>
                    </div>

                    <div id="sr-city-toggle-wrap" class="sr-city-toggle-wrap" aria-live="polite">
                      <label class="sr-city-toggle-label">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                        نطاق الإرسال الجغرافي عند البث العام
                      </label>
                      <div class="sr-city-toggle-chips" id="sr-city-toggle-chips">
                        <button type="button" class="sr-city-toggle-chip active" data-scope="no-city">
                          جميع المدن
                          <small>يرسل إلى المؤهلين كافة بدون تقييد مدينة واحدة.</small>
                        </button>
                        <button type="button" class="sr-city-toggle-chip" data-scope="with-city">
                          مدينة محددة
                          <small>يحصر الوصول على المؤهلين ضمن مدينة بعينها.</small>
                        </button>
                      </div>
                      <div id="sr-dispatch-city-select" class="hidden">
                        <div class="sr-fields-grid sr-fields-grid-two">
                          <div class="form-group sr-group" id="sr-dispatch-region-group" style="margin-bottom:0">
                            <label class="form-label sr-label" for="sr-dispatch-region">المنطقة الإدارية</label>
                            <select id="sr-dispatch-region" class="form-select">
                              <option value="">اختر المنطقة الإدارية</option>
                            </select>
                          </div>
                          <div class="form-group sr-group" style="margin-bottom:0">
                            <label class="form-label sr-label" for="sr-dispatch-city">المدينة</label>
                            <select id="sr-dispatch-city" class="form-select">
                              <option value="">اختر المنطقة أولًا ثم المدينة</option>
                            </select>
                            <small id="sr-dispatch-city-error" class="sr-field-error hidden" role="alert"></small>
                          </div>
                        </div>
                      </div>
                    </div>

                    <div id="sr-map-wrap" class="hidden" aria-live="polite">
                      <div id="sr-selected-provider" class="sr-selected-provider hidden">
                        <img id="sr-selected-provider-avatar" class="sr-selected-provider-avatar" src="" alt="">
                        <div class="sr-selected-provider-info">
                          <strong id="sr-selected-provider-name"></strong>
                          <span id="sr-selected-provider-distance"></span>
                        </div>
                        <div class="sr-selected-provider-actions">
                          <button type="button" class="sr-selected-provider-change" id="sr-selected-provider-change" title="تغيير المزود">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                          </button>
                          <button type="button" class="sr-selected-provider-remove" id="sr-selected-provider-remove" title="إزالة الاختيار">
                            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
                          </button>
                        </div>
                      </div>

                      <div class="sr-map-inline-panel">
                        <div class="sr-map-modal-header">
                          <h3>الخريطة واختيار المزود الأقرب</h3>
                          <button type="button" class="sr-map-inline-refresh" id="sr-map-inline-refresh" aria-label="إعادة تحديد الموقع">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 2v6h-6"/><path d="M3 12a9 9 0 0 1 15.55-6.36L21 8"/><path d="M3 22v-6h6"/><path d="M21 12a9 9 0 0 1-15.55 6.36L3 16"/></svg>
                          </button>
                        </div>
                        <div id="sr-modal-map-canvas" class="sr-modal-map-canvas"></div>
                        <div class="sr-modal-status-bar" id="sr-modal-status-bar">
                          <span class="sr-modal-status-dot"></span>
                          <span id="sr-modal-status-text">جاري تحديد الموقع...</span>
                        </div>
                        <div class="sr-modal-providers-list" id="sr-modal-providers-list">
                          <div class="sr-modal-empty" id="sr-modal-empty">جاري البحث عن مزودين قريبين...</div>
                        </div>
                        <div class="sr-modal-confirm-bar">
                          <button type="button" class="sr-modal-confirm-btn" id="sr-modal-confirm-btn" disabled>تأكيد اختيار المزود</button>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </section>

              <section class="sr-section">
                <div class="sr-section-head">
                  <span class="sr-section-step">3</span>
                  <div>
                    <h2>محتوى الطلب</h2>
                    <p>اكتب العنوان والتفاصيل بشكل مباشر.</p>
                  </div>
                </div>

                <div class="form-group sr-group">
                  <label class="form-label sr-label" for="sr-req-title">عنوان الطلب <span class="sr-required">*</span></label>
                  <input id="sr-req-title" type="text" class="form-input" maxlength="50" placeholder="مثال: تصميم صفحة هبوط لحملة إعلانية" required aria-describedby="sr-req-title-error">
                  <small id="sr-req-title-error" class="sr-field-error hidden" role="alert"></small>
                  <span class="char-count" id="sr-title-count-wrap"><span id="sr-title-count">0</span>/50</span>
                </div>

                <div class="form-group sr-group">
                  <label class="form-label sr-label" for="sr-desc">تفاصيل الطلب <span class="sr-required">*</span></label>
                  <textarea id="sr-desc" class="form-textarea" rows="5" maxlength="500" placeholder="اكتب المطلوب، النتيجة المتوقعة، أي مراجع أو قيود زمنية، وما يجب تسليمه في النهاية..." required aria-describedby="sr-desc-error"></textarea>
                  <small id="sr-desc-error" class="sr-field-error hidden" role="alert"></small>
                  <span class="char-count" id="sr-desc-count-wrap"><span id="sr-desc-count">0</span>/500</span>
                  <p class="sr-helper" id="sr-submit-helper">اذكر المطلوب والنتيجة المتوقعة فقط.</p>
                </div>
              </section>

              <section class="sr-section">
                <div class="sr-section-head">
                  <span class="sr-section-step">4</span>
                  <div>
                    <h2>المرفقات الداعمة</h2>
                    <p>أضف ما تحتاجه فقط.</p>
                  </div>
                </div>

                <div class="form-group sr-group">
                  <label class="form-label sr-label">المرفقات</label>
                  <div class="sr-attachments-wrap">
                    <div id="sr-attachments" class="attachments-preview"></div>
                    <div class="attach-btns">
                      <label class="sr-upload-trigger" for="sr-images">
                        <span class="sr-upload-icon" aria-hidden="true">
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                        </span>
                        <span class="sr-upload-copy">
                          <strong>صور</strong>
                          <span>أعمال مرجعية، لقطات، أو أمثلة مرئية.</span>
                        </span>
                        <input type="file" id="sr-images" accept="image/*" multiple hidden>
                      </label>
                      <label class="sr-upload-trigger" for="sr-videos">
                        <span class="sr-upload-icon" aria-hidden="true">
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="23 7 16 12 23 17 23 7"/><rect x="1" y="5" width="15" height="14" rx="2"/></svg>
                        </span>
                        <span class="sr-upload-copy">
                          <strong>فيديو</strong>
                          <span>مقاطع شرح أو عرض مختصر لسياق الطلب.</span>
                        </span>
                        <input type="file" id="sr-videos" accept="video/*" multiple hidden>
                      </label>
                      <label class="sr-upload-trigger" for="sr-files" style="grid-column:1/-1">
                        <span class="sr-upload-icon" aria-hidden="true">
                          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
                        </span>
                        <span class="sr-upload-copy">
                          <strong>ملفات</strong>
                          <span>ملفات PDF أو مستندات brief أو جداول أو أي مواد داعمة مختصرة.</span>
                        </span>
                        <input type="file" id="sr-files" accept=".pdf,.doc,.docx,.txt,.xlsx,.xls" multiple hidden>
                      </label>
                    </div>
                    <div id="sr-attachment-note" class="sr-attachment-note hidden" role="status" aria-live="polite" aria-atomic="true">
                      <span class="sr-attachment-note-icon" aria-hidden="true">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
                      </span>
                      <div>
                        <strong id="sr-attachment-note-title">تمت إضافة المرفقات</strong>
                        <span id="sr-attachment-note-text">المرفقات المضافة ستُرسل مع الطلب مباشرة.</span>
                      </div>
                    </div>
                  </div>
                </div>
              </section>
            </div>

            <div class="sr-actions">
              <a href="javascript:history.back()" class="sr-cancel-btn" id="sr-cancel">
                <span class="sr-cancel-btn-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
                </span>
                <span class="sr-action-copy">
                  <span>إلغاء</span>
                  <small>الرجوع للصفحة السابقة</small>
                </span>
              </a>
              <button type="submit" class="sr-submit-btn" id="sr-submit">
                <span class="sr-submit-btn-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/></svg>
                </span>
                <span class="sr-action-copy">
                  <span id="sr-submit-text">إرسال الطلب</span>
                  <small>حفظ الطلب ثم تمريره للمسار المناسب</small>
                </span>
              </button>
            </div>
          </form>

          <div id="sr-success" class="success-overlay hidden">
            <div class="success-card sr-success-card">
              <div class="success-icon">✅</div>
              <h2 id="sr-success-title" class="success-title">تم إرسال الطلب</h2>
              <p id="sr-success-message" class="success-msg">تم حفظ طلبك بنجاح. ستتمكن من متابعة حالته وجميع التحديثات من صفحة الطلبات.</p>
              <a href="/orders/" class="btn btn-primary" style="margin-top:16px">عرض طلباتي</a>
              <a href="/" class="btn-link" style="margin-top:8px">العودة للرئيسية</a>
            </div>
          </div>
        </div>
      </div>

      <div id="sr-toast" class="sr-toast" aria-live="polite" aria-atomic="true" role="status">
        <span class="sr-toast-icon" id="sr-toast-icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
        </span>
        <div class="sr-toast-copy">
          <strong id="sr-toast-title">تنبيه مهم</strong>
          <p id="sr-toast-message">ستظهر هنا رسائل التحقق والتنبيه أثناء إرسال الطلب.</p>
        </div>
        <button type="button" class="sr-toast-close" id="sr-toast-close" aria-label="إغلاق التنبيه">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
        <span class="sr-toast-progress" aria-hidden="true"></span>
      </div>
    </div>
  </div>
</main>
{% endblock %}

{% block extra_js %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="{% static 'mobile_web/js/serviceRequestFormPage.js' %}?v=20260418-sr-grand-redesign"></script>
{% endblock %}
