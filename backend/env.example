# Example environment file for local development.
# Copy to `.env` (not committed) and adjust values as needed.

DJANGO_ENV=dev
DJANGO_DEBUG=1
DJANGO_SECRET_KEY=dev-secret-key-change-me
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2

# Local DB options:
# 1) Leave DATABASE_URL empty to use SQLite (backend/db.sqlite3)
# 2) Or use local PostgreSQL:
# DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5432/nawafeth

# Local Redis (optional)
# REDIS_URL=redis://127.0.0.1:6379/0

# Promo home-banner media processing
# 1 in dev and prod by default (can be overridden)
# PROMO_HOME_BANNER_VIDEO_AUTOFIT=1
# Render build helpers (only relevant on hosted builds)
# INSTALL_FFMPEG_ON_BUILD=1
# REQUIRE_FFMPEG=1

# Generic upload media optimization (defaults are already enabled)
# MEDIA_UPLOAD_OPTIMIZATION_ENABLED=1
# MEDIA_IMAGE_OPTIMIZATION_ENABLED=1
# MEDIA_VIDEO_OPTIMIZATION_ENABLED=1
# MEDIA_IMAGE_MAX_DIMENSION=2560
# MEDIA_IMAGE_TARGET_BYTES=1228800
# MEDIA_IMAGE_QUALITY_START=90
# MEDIA_IMAGE_QUALITY_MIN=80
# MEDIA_VIDEO_OPTIMIZE_MIN_MB=10
# MEDIA_VIDEO_OPTIMIZE_MAX_MB=80
# MEDIA_VIDEO_OPTIMIZE_CRF=22
# MEDIA_VIDEO_OPTIMIZE_TIMEOUT_SECONDS=60
# MEDIA_VIDEO_OPTIMIZE_THREADS=1
# PROMO_HOME_BANNER_VIDEO_AUTOFIT_THREADS=1

# CORS (dev)
# CORS_ALLOW_ALL=1

# Render production examples:
# DJANGO_ENV=prod
# DJANGO_DEBUG=0
# DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.onrender.com
# DATABASE_URL=<from-render-postgres>
# REDIS_URL=<from-render-key-value>
# FEATURE_MODERATION_CENTER=1
# FEATURE_ANALYTICS_EVENTS=1
# FEATURE_ANALYTICS_KPI_SURFACES=1
# FEATURE_RBAC_ENFORCE=1
# RBAC_AUDIT_ONLY=0
# PROMO_HOME_BANNER_VIDEO_AUTOFIT=1
# SUBSCRIPTION_REFRESH_INTERVAL_SECONDS=300
# PROMO_PUBLIC_ENDPOINT_CACHE_SECONDS=60
# SITE_TEMPLATE_PAYLOAD_CACHE_TTL=300
# SITE_PUBLIC_PAYLOAD_CACHE_TTL=300
# URGENT_DISPATCH_INLINE_INTERVAL_SECONDS=30
# API_DEFAULT_LIMIT=50
# API_MAX_LIMIT=100
# INSTALL_FFMPEG_ON_BUILD=1
# REQUIRE_FFMPEG=1

# Cloudflare R2 (optional media storage)
# USE_R2_MEDIA=1
# R2_BUCKET_NAME=nawafth-media
# R2_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev   # R2.dev public URL or custom domain
# AWS_ACCESS_KEY_ID=<r2-access-key-id>
# AWS_SECRET_ACCESS_KEY=<r2-secret-access-key>
# AWS_STORAGE_BUCKET_NAME=nawafth-media
# AWS_S3_ENDPOINT_URL=https://<accountid>.r2.cloudflarestorage.com
# AWS_QUERYSTRING_AUTH=0                          # 0 if public URL set, 1 for signed URLs
# AWS_QUERYSTRING_EXPIRE=3600                     # signed URL expiry in seconds

# Firebase Cloud Messaging (optional)
# FIREBASE_PUSH_ENABLED=1
# FIREBASE_PROJECT_ID=<firebase-project-id>
# FIREBASE_CREDENTIALS_PATH=/path/to/firebase-service-account.json
# FIREBASE_CREDENTIALS_JSON={"type":"service_account",...}
# FIREBASE_PUSH_SOUND=default

# Incomplete promo request cleanup (prevent lingering unpaid/missing-asset drafts)
# PROMO_INCOMPLETE_REQUEST_CLEANUP_ENABLED=1
# PROMO_INCOMPLETE_REQUEST_MAX_AGE_MINUTES=30
# PROMO_INCOMPLETE_REQUEST_CLEANUP_LIMIT=200
